{
  "version": "1.2",
  "buttons": {
    "undo-step": {
      "label": "",
      "icon": "undo-2",
      "title": "Шаг назад",
      "styles": {
        "minWidth": "40px",
        "width": "40px",
        "padding": "0",
        "fontSize": "1.02rem",
        "fontWeight": "800"
      },
      "action": { "type": "call", "name": "undoLastStep" }
    },
    "header-reset": {
      "label": "Сброс",
      "title": "Сбросить все параметры",
      "styles": {
        "borderColor": "var(--red)",
        "color": "var(--red)",
        "background": "rgba(255,118,117,0.1)"
      },
      "action": { "type": "call", "name": "resetAll" }
    },
    "collapse-all": {
      "label": "Свернуть",
      "title": "Свернуть все окна",
      "styles": {
        "borderColor": "var(--accent-k)",
        "color": "var(--accent-k)",
        "background": "rgba(0,212,255,0.08)"
      },
      "action": { "type": "call", "name": "toggleAllSections" }
    },
    "translate": {
      "label": "Перевести на EN",
      "icon": "languages",
      "styles": {
        "minWidth": "auto",
        "padding": "6px 14px",
        "fontSize": ".82em"
      },
      "action": { "type": "call", "name": "translateScene" }
    },
    "enhance": {
      "label": "Улучшить AI",
      "icon": "sparkles",
      "styles": {
        "minWidth": "auto",
        "padding": "6px 14px",
        "fontSize": ".82em",
        "color": "var(--accent-k)",
        "borderColor": "rgba(0,212,255,0.3)"
      },
      "action": { "type": "call", "name": "enhancePrompt" }
    },
    "seed-random": {
      "label": "Случайный",
      "icon": "dice-5",
      "styles": {
        "minWidth": "auto",
        "padding": "8px 12px",
        "fontSize": ".82em"
      }
    },
    "seed-clear": {
      "label": "",
      "icon": "x",
      "styles": {
        "minWidth": "auto",
        "padding": "8px 12px",
        "fontSize": ".82em"
      }
    },
    "format-flat": {
      "label": "Flat",
      "attrs": { "data-format": "flat" },
      "action": { "type": "call", "name": "setPromptFormat", "args": ["flat"] }
    },
    "format-structured": {
      "label": "Структурный",
      "attrs": { "data-format": "structured" },
      "action": { "type": "call", "name": "setPromptFormat", "args": ["structured"] }
    },
    "format-midjourney": {
      "label": "Midjourney",
      "attrs": { "data-format": "midjourney" },
      "action": { "type": "call", "name": "setPromptFormat", "args": ["midjourney"] }
    },
    "copy-prompt": {
      "label": "Копировать",
      "icon": "copy"
    },
    "compact": {
      "label": "Компакт",
      "icon": "zap",
      "title": "Свести промпт к минимально нужному ядру"
    },
    "save": {
      "label": "Сохранить",
      "icon": "save"
    },
    "reset": {
      "label": "Сброс",
      "icon": "trash-2"
    }
  }
}
